{
  "name": "aggregation pipeline subset",
  "source": "unified-test-format",
  "status": "supported",
  "setup": [
    {
      "_id": "s1",
      "active": true,
      "score": 7,
      "setDoc": {
        "nested": [
          1,
          2
        ],
        "shape": "same"
      },
      "setNumber": 1,
      "setValue": [
        1,
        2
      ],
      "team": "red"
    },
    {
      "_id": "s2",
      "active": false,
      "score": 5,
      "setDoc": {
        "nested": [
          1,
          2
        ],
        "shape": "same"
      },
      "setNumber": 1.0,
      "setValue": 1,
      "team": "blue"
    },
    {
      "_id": "s3",
      "active": true,
      "score": 11,
      "setDoc": {
        "nested": [
          1,
          2
        ],
        "shape": "same"
      },
      "setNumber": 1,
      "setValue": [
        1,
        2
      ],
      "team": "red"
    }
  ],
  "operations": [
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "team": "red"
          }
        },
        {
          "$sort": {
            "score": -1
          }
        },
        {
          "$project": {
            "_id": 1,
            "score": 1
          }
        },
        {
          "$limit": 1
        }
      ],
      "expect_documents": [
        {
          "_id": "s3",
          "score": 11
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$group": {
            "_id": "all",
            "documents": {
              "$addToSet": "$setDoc"
            },
            "numbers": {
              "$addToSet": "$setNumber"
            },
            "pushed": {
              "$push": "$setValue"
            },
            "values": {
              "$addToSet": "$setValue"
            }
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "all",
          "documents": [
            {
              "nested": [
                1,
                2
              ],
              "shape": "same"
            }
          ],
          "numbers": [
            1
          ],
          "pushed": [
            [
              1,
              2
            ],
            1,
            [
              1,
              2
            ]
          ],
          "values": [
            [
              1,
              2
            ],
            1
          ]
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "active": true
          }
        },
        {
          "$count": "total"
        }
      ],
      "expect_documents": [
        {
          "total": 2
        }
      ]
    },
    {
      "name": "create_index",
      "keys": {
        "team": 1
      },
      "index_name": "team_1",
      "expect_result": {
        "name": "team_1"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "team": "red"
          }
        },
        {
          "$count": "total"
        }
      ],
      "expect_documents": [
        {
          "total": 2
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$group": {
            "_id": "$team",
            "n": {
              "$sum": 1
            },
            "scoreTotal": {
              "$sum": "$score"
            },
            "avgScore": {
              "$avg": "$score"
            },
            "firstId": {
              "$first": "$_id"
            },
            "lastActive": {
              "$last": "$active"
            }
          }
        },
        {
          "$sort": {
            "_id": 1
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "blue",
          "n": 1,
          "scoreTotal": 5,
          "avgScore": 5.0,
          "firstId": "s2",
          "lastActive": false
        },
        {
          "_id": "red",
          "n": 2,
          "scoreTotal": 18,
          "avgScore": 9.0,
          "firstId": "s1",
          "lastActive": true
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$lookup": {
            "from": "other"
          }
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 72,
        "contains": "$lookup"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$unwind": "$team"
        },
        {
          "$project": {
            "_id": 1,
            "team": 1
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "s1",
          "team": "red"
        },
        {
          "_id": "s2",
          "team": "blue"
        },
        {
          "_id": "s3",
          "team": "red"
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "active": true
          }
        },
        {
          "$unwind": "$team"
        },
        {
          "$group": {
            "_id": "$team",
            "ids": {
              "$push": "$_id"
            },
            "uniqueTeams": {
              "$addToSet": "$team"
            }
          }
        },
        {
          "$sort": {
            "_id": 1
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "red",
          "ids": [
            "s1",
            "s3"
          ],
          "uniqueTeams": [
            "red"
          ]
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$count": ""
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 9,
        "contains": "$count"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "team": "none"
          }
        },
        {
          "$group": {
            "_id": "$team",
            "n": {
              "$sum": 1
            }
          }
        }
      ],
      "expect_documents": []
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$group": {
            "_id": {
              "$add": [
                "$team",
                1
              ]
            },
            "n": {
              "$sum": 1
            }
          }
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 72,
        "contains": "$group"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$unwind": {
            "path": "$team",
            "unknown": true
          }
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 72,
        "contains": "unknown"
      }
    }
  ]
}
