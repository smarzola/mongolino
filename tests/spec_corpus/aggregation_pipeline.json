{
  "name": "aggregation pipeline subset",
  "source": "unified-test-format",
  "status": "supported",
  "setup": [
    {
      "_id": "s1",
      "active": true,
      "first": "Ada",
      "last": "Lovelace",
      "owner": "ADA",
      "score": 7,
      "setDoc": {
        "nested": [
          1,
          2
        ],
        "shape": "same"
      },
      "setNumber": 1,
      "setValue": [
        1,
        2
      ],
      "team": "red"
    },
    {
      "_id": "s2",
      "active": false,
      "first": "Grace",
      "last": "Hopper",
      "owner": "grace",
      "score": 5,
      "setDoc": {
        "nested": [
          1,
          2
        ],
        "shape": "same"
      },
      "setNumber": 1.0,
      "setValue": 1,
      "team": "blue"
    },
    {
      "_id": "s3",
      "active": true,
      "first": "Katherine",
      "last": "Johnson",
      "owner": "katherine",
      "score": 11,
      "setDoc": {
        "nested": [
          1,
          2
        ],
        "shape": "same"
      },
      "setNumber": 1,
      "setValue": [
        1,
        2
      ],
      "team": "red"
    }
  ],
  "operations": [
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "team": "red"
          }
        },
        {
          "$sort": {
            "score": -1
          }
        },
        {
          "$project": {
            "_id": 1,
            "score": 1
          }
        },
        {
          "$limit": 1
        }
      ],
      "expect_documents": [
        {
          "_id": "s3",
          "score": 11
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$group": {
            "_id": "all",
            "documents": {
              "$addToSet": "$setDoc"
            },
            "numbers": {
              "$addToSet": "$setNumber"
            },
            "pushed": {
              "$push": "$setValue"
            },
            "values": {
              "$addToSet": "$setValue"
            }
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "all",
          "documents": [
            {
              "nested": [
                1,
                2
              ],
              "shape": "same"
            }
          ],
          "numbers": [
            1
          ],
          "pushed": [
            [
              1,
              2
            ],
            1,
            [
              1,
              2
            ]
          ],
          "values": [
            [
              1,
              2
            ],
            1
          ]
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "active": true
          }
        },
        {
          "$count": "total"
        }
      ],
      "expect_documents": [
        {
          "total": 2
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "_id": "s1"
          }
        },
        {
          "$project": {
            "_id": 0,
            "display": {
              "$concat": [
                "$first",
                " ",
                "$last"
              ]
            },
            "nested": {
              "team": "$team",
              "scoreText": {
                "$toString": "$score"
              }
            }
          }
        },
        {
          "$addFields": {
            "nested.lower": {
              "$toLower": "$display"
            }
          }
        },
        {
          "$set": {
            "total": {
              "$add": [
                4,
                6
              ]
            }
          }
        },
        {
          "$unset": "nested.scoreText"
        }
      ],
      "expect_documents": [
        {
          "display": "Ada Lovelace",
          "nested": {
            "lower": "ada lovelace",
            "team": "red"
          },
          "total": 10
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "_id": "s2"
          }
        },
        {
          "$replaceRoot": {
            "newRoot": {
              "id": "$_id",
              "label": {
                "$concat": [
                  "$first",
                  ":",
                  "$team"
                ]
              }
            }
          }
        }
      ],
      "expect_documents": [
        {
          "id": "s2",
          "label": "Grace:blue"
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "_id": "s3"
          }
        },
        {
          "$replaceWith": {
            "id": "$_id",
            "upperOwner": {
              "$toUpper": "$owner"
            }
          }
        }
      ],
      "expect_documents": [
        {
          "id": "s3",
          "upperOwner": "KATHERINE"
        }
      ]
    },
    {
      "name": "create_index",
      "keys": {
        "team": 1
      },
      "index_name": "team_1",
      "expect_result": {
        "name": "team_1"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "team": "red"
          }
        },
        {
          "$count": "total"
        }
      ],
      "expect_documents": [
        {
          "total": 2
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$group": {
            "_id": {
              "team": "$team",
              "active": "$active"
            },
            "labels": {
              "$push": {
                "$concat": [
                  "$first",
                  ":",
                  "$team"
                ]
              }
            },
            "scorePlusOne": {
              "$sum": {
                "$add": [
                  "$score",
                  1
                ]
              }
            }
          }
        },
        {
          "$sort": {
            "scorePlusOne": -1
          }
        },
        {
          "$limit": 1
        }
      ],
      "expect_documents": [
        {
          "_id": {
            "active": true,
            "team": "red"
          },
          "labels": [
            "Ada:red",
            "Katherine:red"
          ],
          "scorePlusOne": 20
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$lookup": {
            "from": "$$collection",
            "localField": "team",
            "foreignField": "team",
            "as": "peers"
          }
        },
        {
          "$match": {
            "_id": "s2"
          }
        },
        {
          "$project": {
            "_id": 1,
            "peers": 1
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "s2",
          "peers": [
            {
              "_id": "s2",
              "active": false,
              "first": "Grace",
              "last": "Hopper",
              "owner": "grace",
              "score": 5,
              "setDoc": {
                "nested": [
                  1,
                  2
                ],
                "shape": "same"
              },
              "setNumber": 1.0,
              "setValue": 1,
              "team": "blue"
            }
          ]
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$group": {
            "_id": "$team",
            "n": {
              "$sum": 1
            },
            "scoreTotal": {
              "$sum": "$score"
            },
            "avgScore": {
              "$avg": "$score"
            },
            "firstId": {
              "$first": "$_id"
            },
            "lastActive": {
              "$last": "$active"
            }
          }
        },
        {
          "$sort": {
            "_id": 1
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "blue",
          "n": 1,
          "scoreTotal": 5,
          "avgScore": 5.0,
          "firstId": "s2",
          "lastActive": false
        },
        {
          "_id": "red",
          "n": 2,
          "scoreTotal": 18,
          "avgScore": 9.0,
          "firstId": "s1",
          "lastActive": true
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$lookup": {
            "from": "other"
          }
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 9,
        "contains": "localField"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$unwind": "$team"
        },
        {
          "$project": {
            "_id": 1,
            "team": 1
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "s1",
          "team": "red"
        },
        {
          "_id": "s2",
          "team": "blue"
        },
        {
          "_id": "s3",
          "team": "red"
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "active": true
          }
        },
        {
          "$unwind": "$team"
        },
        {
          "$group": {
            "_id": "$team",
            "ids": {
              "$push": "$_id"
            },
            "uniqueTeams": {
              "$addToSet": "$team"
            }
          }
        },
        {
          "$sort": {
            "_id": 1
          }
        }
      ],
      "expect_documents": [
        {
          "_id": "red",
          "ids": [
            "s1",
            "s3"
          ],
          "uniqueTeams": [
            "red"
          ]
        }
      ]
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$count": ""
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 9,
        "contains": "$count"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$match": {
            "team": "none"
          }
        },
        {
          "$group": {
            "_id": "$team",
            "n": {
              "$sum": 1
            }
          }
        }
      ],
      "expect_documents": []
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$group": {
            "_id": {
              "$add": [
                "$team",
                1
              ]
            },
            "n": {
              "$sum": 1
            }
          }
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 9,
        "contains": "$add"
      }
    },
    {
      "name": "aggregate",
      "pipeline": [
        {
          "$unwind": {
            "path": "$team",
            "unknown": true
          }
        }
      ],
      "expect_error": {
        "type": "OperationFailure",
        "code": 72,
        "contains": "unknown"
      }
    }
  ]
}
