    {
      "_id": "u3",
      "name": "Katherine Johnson",
      "bio": "orbital math",
      "tags": [
        "space"
      ],
      "scores": "none",
      "age": 41.0
    },
    {
      "_id": "u4",
      "name": 42,
      "tags": [
        1,
        2
      ]
    }
  ],
  "operations": [
    {
      "name": "find",
      "filter": {
        "name": {
          "$regex": "^ada",
          "$options": "i"
        }
      },
      "expect_documents": [
        {
          "_id": "u1",
          "name": "Ada Lovelace",
          "bio": "first\nprogrammer",
          "tags": [
            "Math",
            "logic"
          ],
          "scores": [
            1,
            2,
            2
          ],
          "profile": {
            "city": "Rome"
          },
          "nothing": null,
          "active": true,
          "age": 37,
          "ratio": 1.5
        }
      ]
    },
    {
      "name": "count_documents",
      "filter": {
        "tags": {
          "$regex": "^mat",
          "$options": "i"
        }
      },
      "expect_result": {
        "count": 1
      }
    },
    {
      "name": "count_documents",
      "filter": {
        "age": {
          "$type": "number"
        }
      },
      "expect_result": {
        "count": 3
      }
    },
    {
      "name": "find",
      "filter": {
        "profile": {
          "$type": "object"
        }
      },
      "projection": {
        "_id": 1
      },
      "expect_documents": [
        {
          "_id": "u1"
        }
      ]
    },
    {
      "name": "find",
      "filter": {
        "tags": {
          "$size": 2
        }
      },
      "projection": {
        "_id": 1
      },
      "expect_documents": [
        {
          "_id": "u1"
        }
      ]
    },
    {
      "name": "find",
      "filter": {
        "tags": {
          "$all": [
            "logic",
            "Math"
          ]
        }
      },
      "projection": {
        "_id": 1
      },
      "expect_documents": [
        {
          "_id": "u1"
        }
      ]
    },
    {
      "name": "find",
      "filter": {
        "tags": {
          "$all": [
            {
              "$elemMatch": {
                "$eq": "Math"
              }
            }
          ]
        }
      },
      "expect_error": {
        "type": "OperationFailure",
        "code": 2,
        "contains": "$all $elemMatch clauses are not supported yet"
      }
    },
    {
      "name": "update_one",
      "filter": {
        "name": {
          "$regex": "hopper$",
          "$options": "i"
        }
      },
      "update": {
        "$set": {
          "matched": "regex"
        }
      },
      "expect_result": {
        "matched_count": 1,
        "modified_count": 1
      }
    },
    {
      "name": "delete_many",
      "filter": {
        "name": {
          "$regex": "son$"
        }
      },
      "expect_result": {
        "deleted_count": 1
      }
    },
    {
      "name": "find",
      "filter": {
        "bio": {
          "$regex": "COBOL.*pioneer",
          "$options": "s"
        }
      },
      "projection": {
        "_id": 1,
        "matched": 1
      },
      "expect_documents": [
        {
          "_id": "u2",
          "matched": "regex"
        }
      ]
    },
    {
      "name": "find",
      "filter": {
        "name": {
          "$regex": "("
        }
      },
      "expect_error": {
        "type": "OperationFailure",
        "code": 2,
        "contains": "invalid $regex pattern"
      }
    }
  ]
}
