{
  "name": "index planner v2 prefix and range",
  "source": "crud",
  "status": "supported",
  "setup": [
    {
      "_id": "e1",
      "account": "a",
      "created": "2026-01-01",
      "state": "queued"
    },
    {
      "_id": "e2",
      "account": "a",
      "created": "2026-02-01",
      "state": "queued"
    },
    {
      "_id": "e3",
      "account": "a",
      "created": "2026-03-01",
      "state": "done"
    },
    {
      "_id": "e4",
      "account": "b",
      "created": "2026-03-01",
      "state": "queued"
    }
  ],
  "operations": [
    {
      "name": "create_index",
      "keys": {
        "account": 1,
        "created": 1
      },
      "index_name": "account_created_1",
      "expect_result": {
        "name": "account_created_1"
      }
    },
    {
      "name": "find",
      "filter": {
        "account": "a"
      },
      "expect_documents": [
        {
          "_id": "e1",
          "account": "a",
          "created": "2026-01-01",
          "state": "queued"
        },
        {
          "_id": "e2",
          "account": "a",
          "created": "2026-02-01",
          "state": "queued"
        },
        {
          "_id": "e3",
          "account": "a",
          "created": "2026-03-01",
          "state": "done"
        }
      ]
    },
    {
      "name": "command",
      "command": {
        "find": "$$collection",
        "filter": {
          "account": "a"
        },
        "hint": "account_created_1",
        "explain": true
      },
      "expect_path_values": [
        {
          "path": [
            "queryPlanner",
            "winningPlan",
            "stage"
          ],
          "value": "IXSCAN"
        },
        {
          "path": [
            "queryPlanner",
            "winningPlan",
            "scanStrategy"
          ],
          "value": "indexEqualityPrefix"
        },
        {
          "path": [
            "queryPlanner",
            "hintProvided"
          ],
          "value": true
        }
      ]
    },
    {
      "name": "command",
      "command": {
        "find": "$$collection",
        "filter": {},
        "sort": {
          "created": 1
        },
        "explain": true
      },
      "expect_path_values": [
        {
          "path": [
            "queryPlanner",
            "winningPlan",
            "scanStrategy"
          ],
          "value": "collectionScan"
        }
      ]
    },
    {
      "name": "count_documents",
      "filter": {
        "account": "a",
        "created": {
          "$gte": "2026-02-01"
        }
      },
      "expect_result": {
        "count": 2
      }
    },
    {
      "name": "command",
      "command": {
        "count": "$$collection",
        "query": {
          "account": "a",
          "created": {
            "$gte": "2026-02-01"
          }
        },
        "explain": true
      },
      "expect_path_values": [
        {
          "path": [
            "queryPlanner",
            "winningPlan",
            "scanStrategy"
          ],
          "value": "indexRange"
        },
        {
          "path": [
            "queryPlanner",
            "winningPlan",
            "indexName"
          ],
          "value": "account_created_1"
        }
      ]
    },
    {
      "name": "command",
      "command": {
        "find": "$$collection",
        "filter": {
          "state": "queued"
        },
        "hint": "account_created_1",
        "explain": true
      },
      "expect_error": {
        "type": "OperationFailure",
        "code": 2,
        "contains": "incompatible"
      }
    },
    {
      "name": "update_many",
      "filter": {
        "account": "a",
        "created": {
          "$gte": "2026-02-01"
        }
      },
      "update": {
        "$set": {
          "state": "range-updated"
        }
      },
      "expect_result": {
        "matched_count": 2,
        "modified_count": 2
      }
    },
    {
      "name": "delete_many",
      "filter": {
        "account": "b",
        "created": {
          "$lte": "2026-03-01"
        }
      },
      "expect_result": {
        "deleted_count": 1
      }
    }
  ],
  "expect_final_documents": [
    {
      "_id": "e1",
      "account": "a",
      "created": "2026-01-01",
      "state": "queued"
    },
    {
      "_id": "e2",
      "account": "a",
      "created": "2026-02-01",
      "state": "range-updated"
    },
    {
      "_id": "e3",
      "account": "a",
      "created": "2026-03-01",
      "state": "range-updated"
    }
  ]
}
