{
  "name": "delete one and many",
  "source": "crud",
  "status": "supported",
  "setup": [
    {
      "_id": "u1",
      "group": "a",
      "kind": "indexed"
    },
    {
      "_id": "u2",
      "group": "a",
      "kind": "indexed"
    },
    {
      "_id": "u3",
      "group": "b",
      "kind": "fallback"
    }
  ],
  "operations": [
    {
      "name": "create_index",
      "keys": {
        "kind": 1
      },
      "index_name": "kind_1"
    },
    {
      "name": "delete_one",
      "filter": {
        "_id": {
          "$eq": "u1"
        }
      },
      "expect_result": {
        "deleted_count": 1
      }
    },
    {
      "name": "delete_many",
      "filter": {
        "kind": "fallback"
      },
      "expect_result": {
        "deleted_count": 1
      }
    },
    {
      "name": "delete_one",
      "filter": {
        "$or": [
          {
            "group": "missing"
          },
          {
            "kind": "indexed"
          }
        ]
      },
      "expect_result": {
        "deleted_count": 1
      }
    }
  ],
  "expect_final_documents": []
}
