{
  "name": "update unsupported push option failure",
  "source": "crud",
  "status": "supported",
  "setup": [
    {
      "_id": "u1",
      "tags": []
    }
  ],
  "operations": [
    {
      "name": "update_one",
      "filter": {
        "_id": "u1"
      },
      "update": {
        "$push": {
          "tags": {
            "$each": [
              "new"
            ],
            "$position": 0
          }
        }
      },
      "expect_error": {
        "type": "WriteError",
        "contains": "$push option $position is not supported"
      }
    }
  ],
  "expect_final_documents": [
    {
      "_id": "u1",
      "tags": []
    }
  ]
}
