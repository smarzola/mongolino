{
  "name": "unique index enforcement",
  "source": "crud",
  "status": "supported",
  "setup": [
    {
      "_id": "u1",
      "email": "ada@example.test"
    },
    {
      "_id": "u2",
      "email": "grace@example.test"
    }
  ],
  "operations": [
    {
      "name": "create_index",
      "keys": {
        "email": 1
      },
      "index_name": "email_1",
      "unique": true,
      "expect_result": {
        "name": "email_1"
      }
    },
    {
      "name": "insert_one",
      "document": {
        "_id": "u3",
        "email": "ada@example.test"
      },
      "expect_error": {
        "type": "DuplicateKeyError",
        "code": 11000,
        "contains": "duplicate key error"
      }
    },
    {
      "name": "drop_index",
      "index_name": "email_1",
      "expect_result": {
        "ok": null
      }
    },
    {
      "name": "insert_one",
      "document": {
        "_id": "u3",
        "email": "ada@example.test"
      },
      "expect_result": {
        "inserted_id": "u3"
      }
    }
  ],
  "expect_final_documents": [
    {
      "_id": "u1",
      "email": "ada@example.test"
    },
    {
      "_id": "u2",
      "email": "grace@example.test"
    },
    {
      "_id": "u3",
      "email": "ada@example.test"
    }
  ]
}
